{
  "name": "clawavatar",
  "productName": "ClawAvatar",
  "version": "1.0.1",
  "description": "OpenClaw Avatar Desktop App - 小龙虾虚拟形象桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.openclaw.avatar",
    "productName": "ClawAvatar",
    "electronVersion": "41.0.2",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "ClawAvatar.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "ClawAvatar needs microphone access for voice input."
      },
      "entitlements": "build/entitlements.plist",
      "entitlementsInherit": "build/entitlements.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    },
    "dmg": {
      "title": "ClawAvatar",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "asar": false
  }
}
